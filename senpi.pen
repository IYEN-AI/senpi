              "fontSize": 30,
              "fontWeight": "800"
            },
            {
              "type": "text",
              "id": "LszEQ",
              "fill": "$senpi-muted",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Use Pencil as the source of truth, but implement manually into the repo's existing frameworks. The design becomes code by reading frames/components, mapping them to existing packages, then validating against screenshots and package checks.",
              "lineHeight": 1.35,
              "fontFamily": "$font-ui",
              "fontSize": 15
            },
